  "material_codes_structure": {
    "bolt_format": {
      "pattern": "BLT-M{diameter}x{length}-{strength}-{coating}",
      "example": "BLT-M06x20-88-ZN",
      "explanation": {
        "BLT": "Болт",
        "M06": "Диаметр 6мм",
        "x20": "Длина 20мм",
        "88": "Класс прочности 8.8",
        "ZN": "Цинк"
      }
    },
    "nut_format": {
      "pattern": "NUT-M{diameter}-{height}-{coating}",
      "example": "NUT-M06-8-ZN",
      "explanation": {
        "NUT": "Гайка",
        "M06": "Диаметр 6мм",
        "8": "Высота",
        "ZN": "Цинк"
      }
    },
    "washer_format": {
      "pattern": "WSH-{diameter}-{type}-{material}",
      "example": "WSH-06-PLAIN-ZN",
      "explanation": {
        "WSH": "Шайба",
        "06": "Диаметр 6мм",
        "PLAIN": "Плоская",
        "ZN": "Цинк"
      }
    },
    "steel_bar_format": {
      "pattern": "ST-BAR-{grade}-{diameter}",
      "example": "ST-BAR-45-010",
      "explanation": {
        "ST": "Сталь",
        "BAR": "Пруток",
        "45": "Марка стали",
        "010": "Диаметр 10мм"
      }
    },
    "wire_format": {
      "pattern": "CU-WIRE-{insulation}-{diameter}",
      "example": "CU-WIRE-PETV2-050",
      "explanation": {
        "CU": "Медь",
        "WIRE": "Провод",
        "PETV2": "Тип изоляции",
        "050": "Диаметр 0.50мм"
      }
    },
    "bearing_format": {
      "pattern": "BRG-{series}-{sealing}",
      "example": "BRG-6204-2RS1",
      "explanation": {
        "BRG": "Подшипник",
        "6204": "Серия",
        "2RS1": "Двустороннее уплотнение"
