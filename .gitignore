```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
vendor/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS specific
.DS_Store
Thumbs.db

# Coverage
.coverage
coverage/
htmlcov/

# Build directories
dist/
build/
target/
```