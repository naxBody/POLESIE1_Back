```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Dependencies
venv/
.venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Coverage
.coverage
coverage/
htmlcov/

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```