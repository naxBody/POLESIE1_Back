```gitignore
# Dependencies
vendor/

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.coverage
coverage/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java
*.class
*.jar
*.war
*.ear
*.iml
.gradle/
build/
target/

# PHP
*.php~
.htaccess
web.config

# CSS/JS build tools
.sass-cache/
.npm/
.yarn/
bower_components/

# Compression archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```